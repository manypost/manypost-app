# postaq — configuração mínima (validada por packages/config, fail-fast)
MODE=all
PORT=3000
PUBLIC_URL=http://localhost:3000

DATABASE_URL=postgresql://postaq:postaq@localhost:5432/postaq
REDIS_URL=redis://localhost:6379

# Segredos DISTINTOS (o boot falha se forem iguais)
JWT_SECRET=change-me-random-string-with-at-least-32-chars
# openssl rand -hex 32
ENCRYPTION_KEY=

STORAGE_PROVIDER=local
UPLOAD_DIR=./uploads

# IA agnóstica de provedor (none = recursos de IA desligados, UI degrada)
AI_PROVIDER=none
#AI_BASE_URL=
#AI_API_KEY=
#AI_MODEL=

LOG_LEVEL=info
#OTEL_EXPORTER_OTLP_ENDPOINT=

# Credenciais por rede social (provider sem env some do catálogo)
#LINKEDIN_CLIENT_ID=
#LINKEDIN_CLIENT_SECRET=
#X_API_KEY=
#X_API_SECRET=
#DISCORD_CLIENT_ID=
#DISCORD_CLIENT_SECRET=
#TELEGRAM_BOT_TOKEN=
#MASTODON_DEFAULT_INSTANCE=https://mastodon.social
