# manypost — configuração mínima (validada por packages/config, fail-fast)
MODE=all
PORT=3000
# Origem do produto para PESSOAS (interface web): OAuth dos canais, link de aprovação,
# URL pública da mídia e cookies saem daqui. Não é o endereço da API para máquinas.
PUBLIC_URL=http://localhost:3000

# Superfícies de MÁQUINA em hosts dedicados (SPEC_API_MCP §3/§5) — opcionais.
# São o MESMO serviço de API (2º e 3º domínio custom apontando para ele): o roteamento é por
# Host, sem proxy do Next no meio. Deixe vazio no self-host de um domínio só — aí a API de
# máquina fica em {PUBLIC_URL}/public/v1 e o MCP em {PUBLIC_URL}/mcp.
#   api. → API REST das integrações em /v1 (chave mp_live_ em Authorization: Bearer)
#   mcp. → servidor MCP na RAIZ (é a URL que o usuário cola no Claude/Cursor)
# API_PUBLIC_URL=https://api.manypost.com.br
# MCP_PUBLIC_URL=https://mcp.manypost.com.br
#
# ATENÇÃO ao proxy do web: o `API_URL` do apps/web (destino do rewrite de /v1) precisa apontar
# para um host DIFERENTE destes — normalmente o endereço interno do serviço de API. Se o proxy
# bater no mesmo host de API_PUBLIC_URL, o /v1 que o web usa cairia na superfície de máquina.
# Em dev (web 3000 → API 3100) dá para exercitar os hosts sem DNS usando nomes de loopback
# distintos, mantendo o proxy em localhost:
#   API_PUBLIC_URL=http://127.0.0.1:3100
#   MCP_PUBLIC_URL=http://127.0.0.2:3100

# Estratégia 100% Open Source / Open Core (Community vs Cloud / SaaS, controlada por flags):
# true = modo Community/Self-Hosted (recursos liberados e limites sem cobrança)
# false = modo Cloud / SaaS (ativa enforcement comercial de planos Grátis/Pro/Premium)
IS_SELF_HOSTED=true
# true = oculta botões de upgrade e telas de faturamento da Stripe na UI
HIDE_BILLING=true

# Cobrança (Stripe) — SÓ no gerenciado (IS_SELF_HOSTED=false e HIDE_BILLING=false).
# Sem STRIPE_SECRET_KEY não há cobrança nem bloqueio de plano: a instalação roda liberada.
# Passo a passo: 1) bun run stripe:sync cria os produtos/preços do catálogo na sua conta;
# 2) bun run stripe:webhook https://seu-dominio registra {PUBLIC_URL}/v1/stripe/webhook e
#    imprime o whsec_ (em dev: stripe listen --forward-to localhost:3100/v1/stripe/webhook).
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# 0 = sem teste grátis (o plano Grátis já é permanente)
# BILLING_TRIAL_DAYS=0


DATABASE_URL=postgresql://manypost:manypost@localhost:5432/manypost
REDIS_URL=redis://localhost:6379

# Segredos DISTINTOS (o boot falha se forem iguais)
JWT_SECRET=change-me-random-string-with-at-least-32-chars
# openssl rand -hex 32
ENCRYPTION_KEY=

STORAGE_PROVIDER=local
UPLOAD_DIR=./uploads
# Limites de upload por tipo (MB)
MEDIA_MAX_IMAGE_MB=10
MEDIA_MAX_VIDEO_MB=200
# true só em dev/e2e: permite /v1/media/from-url apontar p/ rede privada (anti-SSRF desligado)
#MEDIA_ALLOW_PRIVATE_URLS=false

# IA agnóstica de provedor (none = recursos de IA desligados, UI degrada)
AI_PROVIDER=none
#AI_BASE_URL=
#AI_API_KEY=
#AI_MODEL=

LOG_LEVEL=info
#OTEL_EXPORTER_OTLP_ENDPOINT=
# /metrics (Prometheus): setado = exige Authorization: Bearer <token>; vazio = /metrics aberto
#METRICS_TOKEN=

# Login social (opcional — sem env, o botão não aparece na tela de login)
# Como conseguir: docs/principal/INTEGRATIONS_SETUP.md §"Login social"
#GOOGLE_CLIENT_ID=
#GOOGLE_CLIENT_SECRET=
#GITHUB_CLIENT_ID=
#GITHUB_CLIENT_SECRET=

# Credenciais por rede social (provider sem env some do catálogo).
# COMO CONSEGUIR CADA UMA, passo a passo e sem tecniquês: docs/principal/INTEGRATIONS_SETUP.md
#MASTODON_DEFAULT_INSTANCE=https://mastodon.social
# Bluesky: não precisa de env (handle + app password na tela de conexão)
#TELEGRAM_BOT_TOKEN=
# Discord (modo principal OAuth2 + Bot):
#DISCORD_CLIENT_ID=
#DISCORD_CLIENT_SECRET=
#DISCORD_BOT_TOKEN=
# (Para usar Discord via Webhook leve sem app, não precisa de env — basta colar a URL do webhook na tela)
#REDDIT_CLIENT_ID=
#REDDIT_CLIENT_SECRET=
#LINKEDIN_CLIENT_ID=
#LINKEDIN_CLIENT_SECRET=
#X_CLIENT_ID=
#X_CLIENT_SECRET=
#PINTEREST_APP_ID=
#PINTEREST_APP_SECRET=
#YOUTUBE_CLIENT_ID=
#YOUTUBE_CLIENT_SECRET=
# Facebook Pages (produto "Facebook Login" no app Meta; redirect: PUBLIC_URL/v1/channels/callback/facebook
# — precisa ser HTTPS; escopos: pages_show_list, business_management, pages_manage_posts,
# pages_manage_engagement, pages_read_engagement, read_insights. A Página é escolhida por post no
# compositor. A Meta faz *pull* da mídia: a URL do arquivo tem que ser pública — docs §5.2):
#FACEBOOK_APP_ID=
#FACEBOOK_APP_SECRET=
# Threads (app Meta com o caso de uso "Threads API"; redirect: PUBLIC_URL/v1/channels/callback/threads
# — precisa ser HTTPS; escopos: threads_basic, threads_content_publish, threads_manage_replies,
# threads_manage_insights. A Meta faz *pull* da mídia: a URL do arquivo tem que ser pública — docs §5.4):
#THREADS_APP_ID=
#THREADS_APP_SECRET=
# Instagram standalone (Instagram Login, SEM Página do Facebook — produto "Instagram" no app Meta;
# redirect: PUBLIC_URL/v1/channels/callback/instagram-standalone — HTTPS; escopos: instagram_business_basic,
# instagram_business_content_publish, instagram_business_manage_comments, instagram_business_manage_insights.
# Conta precisa ser comercial/criador. A Meta faz *pull* da mídia: a URL do arquivo tem que ser pública):
#INSTAGRAM_APP_ID=
#INSTAGRAM_APP_SECRET=
# Twitch (publica no CHAT ao vivo ou como anúncio do canal — não é feed de posts;
# app em dev.twitch.tv/console/apps; redirect: PUBLIC_URL/v1/channels/callback/twitch;
# escopos: user:write:chat, user:read:chat, moderator:manage:announcements):
#TWITCH_CLIENT_ID=
#TWITCH_CLIENT_SECRET=
# Kick (publica no CHAT ao vivo; app em kick.com/settings/developer, OAuth 2.1 + PKCE;
# redirect: PUBLIC_URL/v1/channels/callback/kick; escopos: chat:write, user:read, channel:read):
#KICK_CLIENT_ID=
#KICK_CLIENT_SECRET=
# TikTok (Content Posting API — Login Kit; redirect: PUBLIC_URL/v1/channels/callback/tiktok;
# escopos: user.info.basic, user.info.profile, video.publish, video.upload — docs §5.3):
#TIKTOK_CLIENT_KEY=
#TIKTOK_CLIENT_SECRET=
