# manypost — configuração mínima (validada por packages/config, fail-fast)
MODE=all
PORT=3000
PUBLIC_URL=http://localhost:3000

# Estratégia 100% Open Source / Open Core (Community vs Cloud / SaaS, estilo Postiz):
# true = modo Community/Self-Hosted (recursos liberados e limites sem cobrança)
# false = modo Cloud / SaaS (ativa enforcement comercial de planos Grátis/Pro/Premium)
IS_SELF_HOSTED=true
# true = oculta botões de upgrade e telas de faturamento da Stripe na UI
HIDE_BILLING=true

# Cobrança (Stripe) — SÓ no gerenciado (IS_SELF_HOSTED=false e HIDE_BILLING=false).
# Sem STRIPE_SECRET_KEY não há cobrança nem bloqueio de plano: a instalação roda liberada.
# Passo a passo: 1) bun run stripe:sync cria os produtos/preços do catálogo na sua conta;
# 2) crie o webhook apontando para {PUBLIC_URL}/v1/stripe/webhook com os eventos
#    customer.subscription.created/updated/deleted e copie o whsec_ abaixo.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# 0 = sem teste grátis (o plano Grátis já é permanente)
# BILLING_TRIAL_DAYS=0


DATABASE_URL=postgresql://manypost:manypost@localhost:5432/manypost
REDIS_URL=redis://localhost:6379

# Segredos DISTINTOS (o boot falha se forem iguais)
JWT_SECRET=change-me-random-string-with-at-least-32-chars
# openssl rand -hex 32
ENCRYPTION_KEY=

STORAGE_PROVIDER=local
UPLOAD_DIR=./uploads
# Limites de upload por tipo (MB)
MEDIA_MAX_IMAGE_MB=10
MEDIA_MAX_VIDEO_MB=200
# true só em dev/e2e: permite /v1/media/from-url apontar p/ rede privada (anti-SSRF desligado)
#MEDIA_ALLOW_PRIVATE_URLS=false

# IA agnóstica de provedor (none = recursos de IA desligados, UI degrada)
AI_PROVIDER=none
#AI_BASE_URL=
#AI_API_KEY=
#AI_MODEL=

LOG_LEVEL=info
#OTEL_EXPORTER_OTLP_ENDPOINT=
# /metrics (Prometheus): setado = exige Authorization: Bearer <token>; vazio = /metrics aberto
#METRICS_TOKEN=

# Login social (opcional — sem env, o botão não aparece na tela de login)
# Como conseguir: docs/INTEGRATIONS_SETUP.md §"Login social"
#GOOGLE_CLIENT_ID=
#GOOGLE_CLIENT_SECRET=
#GITHUB_CLIENT_ID=
#GITHUB_CLIENT_SECRET=

# Credenciais por rede social (provider sem env some do catálogo).
# COMO CONSEGUIR CADA UMA, passo a passo e sem tecniquês: docs/INTEGRATIONS_SETUP.md
#MASTODON_DEFAULT_INSTANCE=https://mastodon.social
# Bluesky: não precisa de env (handle + app password na tela de conexão)
#TELEGRAM_BOT_TOKEN=
# Discord (Modo Principal OAuth2 + Bot — paridade Postiz):
#DISCORD_CLIENT_ID=
#DISCORD_CLIENT_SECRET=
#DISCORD_BOT_TOKEN=
# (Para usar Discord via Webhook leve sem app, não precisa de env — basta colar a URL do webhook na tela)
#REDDIT_CLIENT_ID=
#REDDIT_CLIENT_SECRET=
#LINKEDIN_CLIENT_ID=
#LINKEDIN_CLIENT_SECRET=
#X_CLIENT_ID=
#X_CLIENT_SECRET=
#PINTEREST_APP_ID=
#PINTEREST_APP_SECRET=
#YOUTUBE_CLIENT_ID=
#YOUTUBE_CLIENT_SECRET=
#FACEBOOK_APP_ID=
#FACEBOOK_APP_SECRET=
#THREADS_APP_ID=
#THREADS_APP_SECRET=
# TikTok (Content Posting API — Login Kit; redirect: PUBLIC_URL/v1/channels/callback/tiktok;
# escopos: user.info.basic, user.info.profile, video.publish, video.upload — docs §5.3):
#TIKTOK_CLIENT_KEY=
#TIKTOK_CLIENT_SECRET=
