{
  "name": "manypost-monorepo",
  "private": true,
  "license": "AGPL-3.0-only",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "bun": ">=1.2.0"
  },
  "scripts": {
    "dev": "bun run --cwd apps/api dev",
    "dev:worker": "bun run --cwd apps/worker dev",
    "dev:web": "bun run --cwd apps/web dev",
    "dev:all": "bun run scripts/dev-all.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:web": "bun run --cwd apps/web typecheck",
    "test": "bun test",
    "check:boundaries": "depcruise apps packages --config .dependency-cruiser.cjs",
    "check:ai-providers": "bun run scripts/check-ai-providers.ts",
    "check:brand": "bun run scripts/check-brand.ts",
    "stripe:sync": "bun run scripts/stripe-sync.ts",
    "check": "bun run typecheck && bun run typecheck:web && bun run test && bun run check:boundaries && bun run check:ai-providers && bun run check:brand"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "bun-types": "^1.2.0",
    "dependency-cruiser": "^16.10.0",
    "typescript": "^5.8.0"
  }
}
